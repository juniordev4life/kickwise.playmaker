NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Auth / Sessions
JWT_SECRET=change-me-to-a-256-bit-random-string
JWT_TTL_DAYS=30
COOKIE_NAME=kickwise_token
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Winger
WINGER_URL=http://localhost:3001

# Google Cloud
BQ_PROJECT_ID=kickwise-prod
BQ_DATASET=kickwise_main
GCP_PROJECT_ID=kickwise-prod

# Local dev against Firestore emulator
# FIRESTORE_EMULATOR_HOST=localhost:8080
